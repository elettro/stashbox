# Stashbox Radio DEV v2 Lambda environment template
# Copy values into the AWS Lambda console or deployment secret store later.
# Do not commit real credentials or tokens.

APP_ENV=dev
AD_SETTINGS_ID=dev

# Database: recommended initial target is the existing RDS instance with a DEV-only schema.
PGHOST=<existing-rds-endpoint>
PGPORT=5432
PGDATABASE=<existing-database-name>
PGSCHEMA=radio_dev
PGUSER=<dev-scoped-db-user>
PGPASSWORD=<dev-db-password>

# Admin: must be DEV-only and must not reuse production.
ADMIN_TOKEN=<dev-admin-token>

# Uploads: DEV-only S3 bucket in us-east-1.
UPLOAD_BUCKET=stashbox-radio-media-dev-us-east-1
UPLOAD_REGION=us-east-1
UPLOAD_PUBLIC_BASE_URL=https://stashbox-radio-media-dev-us-east-1.s3.us-east-1.amazonaws.com

# Public route identity for DEV player tracking defaults.
PUBLIC_PLAYER_PATH=/radio/dev/

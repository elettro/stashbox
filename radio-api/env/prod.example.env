# Stashbox Radio PROD Lambda environment template
# This file is documentation only. Do not paste DEV values here.
# Do not commit real credentials or tokens.

APP_ENV=prod
AD_SETTINGS_ID=prod

PGHOST=<production-rds-endpoint>
PGPORT=5432
PGDATABASE=<production-database-name>
PGSCHEMA=radio
PGUSER=<production-db-user>
PGPASSWORD=<production-db-password>

ADMIN_TOKEN=<production-admin-token>

UPLOAD_BUCKET=<production-media-bucket>
UPLOAD_REGION=<production-media-region>
UPLOAD_PUBLIC_BASE_URL=<production-public-media-base-url>

PUBLIC_PLAYER_PATH=/radio/
